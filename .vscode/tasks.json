{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure the CMake project."
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "group": "build",
            "dependsOn": [
                "CMake: Configure"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the CMake project."
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "./build/run_tests",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "CMake: Build"
            ],
            "problemMatcher": [],
            "detail": "Run the test suite."
        }
    ]
}
